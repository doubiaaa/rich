# Mail settings
# QQ 邮箱：SMTP_SERVER=smtp.qq.com
# 端口 587 用 STARTTLS；端口 465 用 SSL（云服务器若 587 不通可改 465）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
EMAIL_SENDER=your_sender@qq.com
EMAIL_PASSWORD=your_smtp_password_or_app_password
EMAIL_RECEIVER=receiver1@example.com,receiver2@example.com

# Strategy runtime options
# true/false
ENABLE_MINUTE=false
